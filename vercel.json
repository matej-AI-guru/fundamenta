{
  "crons": [
    {
      "path": "/api/scrape?offset=0&limit=10",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/scrape?offset=10&limit=10",
      "schedule": "10 6 * * *"
    },
    {
      "path": "/api/scrape?offset=20&limit=10",
      "schedule": "20 6 * * *"
    },
    {
      "path": "/api/scrape?offset=30&limit=10",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/scrape?offset=40",
      "schedule": "40 6 * * *"
    },
    {
      "path": "/api/status",
      "schedule": "55 6 * * *"
    },
    {
      "path": "/api/alerts/send",
      "schedule": "0 7 * * *"
    }
  ],
  "functions": {
    "app/api/scrape/route.ts": {
      "maxDuration": 300
    }
  }
}
